# ================================================================
#  NexCall AI — Fichier de configuration
#  Copiez ce fichier vers .env et remplissez les valeurs
#  cp .env.example .env
# ================================================================

# --- Application ---
APP_NAME="NexCall AI"
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=true
SECRET_KEY=changez-cette-cle-secrete-en-production-32-chars

# --- Base de données ---
# SQLite (développement)
DATABASE_URL=sqlite+aiosqlite:///./nexcall.db
# PostgreSQL (production) — décommentez et adaptez :
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/nexcall

# ----------------------------------------------------------------
#  VAPI.AI — Appels IA sortants
#  Dashboard : https://dashboard.vapi.ai
# ----------------------------------------------------------------
VAPI_API_KEY=votre_cle_privee_vapi
VAPI_API_URL=https://api.vapi.ai
VAPI_PHONE_NUMBER_ID=uuid-du-numero-vapi
VAPI_ASSISTANT_ID=uuid-de-l-assistant
VAPI_WEBHOOK_SECRET=
TRANSFER_NUMBER=+33XXXXXXXXX

# ----------------------------------------------------------------
#  AUTHENTIFICATION (Dashboard protege par login)
# ----------------------------------------------------------------
JWT_SECRET=changez-cette-cle-jwt-en-production-32-caracteres-min
JWT_EXPIRE_HOURS=168
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ----------------------------------------------------------------
#  FOURNISSEURS IA — Intelligence Artificielle
#  La plateforme n'impose aucun fournisseur. Chaque agent peut
#  utiliser OpenAI, Anthropic, Mistral ou un endpoint compatible.
#  Renseignez uniquement la/les cle(s) du/des fournisseur(s) utilise(s).
# ----------------------------------------------------------------

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-votre_cle_openai
OPENAI_MODEL=gpt-4o
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
# Voix disponibles : alloy, echo, fable, onyx, nova, shimmer
OPENAI_STT_MODEL=whisper-1
OPENAI_MAX_TOKENS=600

# Anthropic (Claude) — optionnel
# ANTHROPIC_API_KEY=sk-ant-votre_cle

# Mistral — optionnel
# MISTRAL_API_KEY=votre_cle_mistral

# Fournisseur personnalise compatible OpenAI (Azure, vLLM, etc.) — optionnel
# CUSTOM_AI_BASE_URL=https://votre-endpoint/v1
# CUSTOM_AI_API_KEY=votre_cle

# ----------------------------------------------------------------
#  AGENT IA — Personnalité
# ----------------------------------------------------------------
AI_AGENT_NAME=Sophie
AI_COMPANY_NAME=AssurancePro
AI_LANGUAGE=fr
AI_TEMPERATURE=0.7

# ----------------------------------------------------------------
#  IVR — Menu vocal interactif
# ----------------------------------------------------------------
IVR_GREETING="Bonjour et bienvenue chez AssurancePro. Pour l'assurance auto, tapez 1. Pour l'assurance santé, tapez 2. Pour parler à un conseiller, tapez 3."

# ----------------------------------------------------------------
#  LEADS — Qualification
# ----------------------------------------------------------------
LEAD_SCORE_THRESHOLD=70
